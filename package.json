{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:client": "pnpm --filter @swifty-chatbot/client dev",
    "dev:server": "pnpm --filter @swifty-chatbot/server dev",
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "format:client": "pnpm --filter @swifty-chatbot/client format",
    "format:server": "pnpm --filter @swifty-chatbot/server format",
    "format": "concurrently \"pnpm format:client\" \"pnpm format:server\"",
    "lint:client": "pnpm --filter @swifty-chatbot/client lint",
    "lint:server": "pnpm --filter @swifty-chatbot/server check",
    "lint": "concurrently \"pnpm lint:client\" \"pnpm lint:server\"",
    "build:client": "pnpm --filter @swifty-chatbot/client build",
    "build:server": "pnpm --filter @swifty-chatbot/server build",
    "build": "concurrently \"pnpm build:client\" \"pnpm build:server\"",
    "git:commit": "git add -A && git commit -m \"feat: Introduce new features\"",
    "git:push": "pnpm git:commit && git push origin main"
  }
}
